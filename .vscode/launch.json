{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch (Debug)",
      "type": "lldb",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/bin/gl_choco_engine",
      "preLaunchTask": "build_debug"
    },
    {
      "name": "Launch (San: ASan+UBSan, Leak ON)",
      "type": "lldb",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/bin/gl_choco_engine",
      "preLaunchTask": "build_san",
      "env": {
        "ASAN_OPTIONS": "halt_on_error=1:abort_on_error=1:detect_leaks=1",
        "UBSAN_OPTIONS": "print_stacktrace=1:halt_on_error=1"
      }
    },
    {
      "name": "Launch (San: ASan+UBSan, Leak OFF)",
      "type": "lldb",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/bin/gl_choco_engine",
      "preLaunchTask": "build_san",
      "env": {
        "ASAN_OPTIONS": "halt_on_error=1:abort_on_error=1:detect_leaks=0",
        "UBSAN_OPTIONS": "print_stacktrace=1:halt_on_error=1"
      }
    }
  ]
}
